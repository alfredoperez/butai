{
  "name": "@butai/docs-kit",
  "version": "0.1.0-beta.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "catalog",
    "registry"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "gen": "tsx scripts/gen.ts",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@butai/patterns": "workspace:*",
    "@butai/themes": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.0",
    "yaml": "^2.6.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  }
}
